# UteRun Townsville — Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=uterun

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Stripe (test mode keys start with sk_test_ / pk_test_)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_FROM_NUMBER=+614xxxxxxxx

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Frontend URL (for CORS and Stripe redirect URLs)
FRONTEND_URL=https://your-domain.com

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8081,http://localhost:19006

# Admin account
ADMIN_PASSWORD=ChangeThisToSomethingStrong!2026
